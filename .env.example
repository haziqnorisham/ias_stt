FLASK_APP=run.py
FLASK_ENV=development
FLASK_PORT=5000

# Frontend (serves the /traps management UI). Set to false to return 404.
ENABLE_FRONTEND=true

# Security: API key for /api/* and the web UI login.
# If unset, authentication is DISABLED (a warning is logged on startup).
API_KEY=

# Database (SQLite). Override to use another engine; defaults to data/traps.db
# DATABASE_URL=sqlite:///data/traps.db

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mqtt_data
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password

# MQTT
MQTT_ENABLED=true
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
# Comma-separated topics. '+' matches exactly ONE level, '#' matches the rest.
# The pattern must have the same number of levels as the published topic, e.g.
# ChirpStack v4 publishes application/<id>/device/<devEUI>/event/<type>, so use
# application/<id>/device/+/event/+  (NOT .../device/+/event which is one level short)
MQTT_TOPICS=topic1,topic2
MQTT_CLIENT_ID=flask_service_001
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_KEEPALIVE=60

# Processing
BATCH_SIZE=100
PROCESSING_INTERVAL=5

# uWSGI (Docker / production)
UWSGI_PROCESSES=2
UWSGI_THREADS=2
